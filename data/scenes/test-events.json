{
  "id": "test-events",
  "entryNode": "start",
  "background": null,
  "music": null,
  "nodes": [
    {
      "id": "start",
      "type": "event",
      "eventType": "bgm",
      "eventValue": "ambient_city",
      "next": "intro",
      "x": 400, "y": 30
    },
    {
      "id": "intro",
      "type": "dialogue",
      "speaker": "narrator",
      "text": "EVENT TEST: The city hums around you. Each action triggers an event.",
      "next": "choose_effect",
      "x": 400, "y": 130
    },
    {
      "id": "choose_effect",
      "type": "choice",
      "prompt": "Pick an effect to trigger:",
      "next": "trigger_done",
      "choices": [
        {
          "text": "Camera shake (intense)",
          "next": "do_shake"
        },
        {
          "text": "Flash the screen",
          "next": "do_flash"
        },
        {
          "text": "Set variable + play SFX",
          "next": "do_sfx_var"
        },
        {
          "text": "Wait 3 seconds",
          "next": "do_wait"
        }
      ],
      "x": 400, "y": 230
    },
    {
      "id": "do_shake",
      "type": "event",
      "eventType": "camera_shake",
      "eventValue": "500,0.01",
      "next": "event_done",
      "x": 100, "y": 340
    },
    {
      "id": "do_flash",
      "type": "event",
      "eventType": "camera_flash",
      "eventValue": "255,255,255",
      "next": "event_done",
      "x": 250, "y": 340
    },
    {
      "id": "do_sfx_var",
      "type": "event",
      "eventType": "sfx",
      "eventValue": "alert",
      "setFlag": "alert_triggered",
      "setValue": true,
      "next": "event_done",
      "x": 400, "y": 340
    },
    {
      "id": "do_wait",
      "type": "wait",
      "duration": 3000,
      "next": "event_done",
      "x": 550, "y": 340
    },
    {
      "id": "event_done",
      "type": "dialogue",
      "speaker": "narrator",
      "text": "Event executed! The world reacts.",
      "next": "try_another",
      "x": 400, "y": 440
    },
    {
      "id": "try_another",
      "type": "choice",
      "prompt": "Try another effect?",
      "next": "trigger_done",
      "choices": [
        {
          "text": "Yes, let me try another",
          "next": "choose_effect"
        },
        {
          "text": "No, finish the test",
          "next": "end"
        }
      ],
      "x": 400, "y": 540
    },
    {
      "id": "end",
      "type": "end",
      "text": "— EVENT TEST COMPLETE —",
      "x": 400, "y": 640
    }
  ]
