{
  "id": "test-conditions",
  "entryNode": "start",
  "background": null,
  "music": null,
  "nodes": [
    {
      "id": "start",
      "type": "dialogue",
      "speaker": "narrator",
      "text": "CONDITION TEST: Your courage is being tested.",
      "next": "check_courage",
      "x": 400, "y": 30
    },
    {
      "id": "check_courage",
      "type": "condition",
      "condition": "courage >= 50",
      "next": "brave_path",
      "else": "coward_path",
      "x": 400, "y": 130
    },
    {
      "id": "brave_path",
      "type": "dialogue",
      "speaker": "narrator",
      "text": "BRAVE PATH: Your courage is strong. You face the challenge head-on.",
      "next": "brave_choice",
      "x": 200, "y": 230
    },
    {
      "id": "coward_path",
      "type": "dialogue",
      "speaker": "narrator",
      "text": "COWARD PATH: Your courage wavers. You look for another way.",
      "next": "coward_choice",
      "x": 600, "y": 230
    },
    {
      "id": "brave_choice",
      "type": "choice",
      "prompt": "You see a dark corridor. What now?",
      "next": "end_default",
      "choices": [
        {
          "text": "Charge forward!",
          "next": "brave_end",
          "setFlag": "courage",
          "setValue": 10
        },
        {
          "text": "Proceed carefully.",
          "next": "cautious_end",
          "setFlag": "courage",
          "setValue": 5
        }
      ],
      "x": 200, "y": 330
    },
    {
      "id": "coward_choice",
      "type": "choice",
      "prompt": "You find a side passage. What now?",
      "next": "end_default",
      "choices": [
        {
          "text": "Sneak through the shadows.",
          "next": "sneak_end",
          "condition": "has_weapon_permit == false",
          "setFlag": "courage",
          "setValue": 15
        },
        {
          "text": "Turn back while you can.",
          "next": "turn_back_end",
          "setFlag": "courage",
          "setValue": -10
        }
      ],
      "x": 600, "y": 330
    },
    {
      "id": "brave_end",
      "type": "dialogue",
      "speaker": "narrator",
      "text": "You charge into the darkness, heart pounding. The way is clear.",
      "next": "final_check",
      "x": 100, "y": 440
    },
    {
      "id": "cautious_end",
      "type": "dialogue",
      "speaker": "narrator",
      "text": "You move slowly, checking every corner. Safety over speed.",
      "next": "final_check",
      "x": 300, "y": 440
    },
    {
      "id": "sneak_end",
      "type": "dialogue",
      "speaker": "narrator",
      "text": "You slip through the passage unseen. Your unarmed status keeps you light on your feet.",
      "next": "final_check",
      "x": 500, "y": 440
    },
    {
      "id": "turn_back_end",
      "type": "dialogue",
      "speaker": "narrator",
      "text": "You retreat. Sometimes discretion is the better part of valor.",
      "next": "final_check",
      "x": 700, "y": 440
    },
    {
      "id": "final_check",
      "type": "condition",
      "condition": "courage >= 70",
      "next": "hero_ending",
      "else": "normal_ending",
      "x": 400, "y": 540
    },
    {
      "id": "hero_ending",
      "type": "dialogue",
      "speaker": "narrator",
      "text": "HERO ENDING: Your courage has reshaped your destiny. You emerge victorious.",
      "next": "end",
      "x": 250, "y": 640
    },
    {
      "id": "normal_ending",
      "type": "dialogue",
      "speaker": "narrator",
      "text": "NORMAL ENDING: You survived. Sometimes that's enough.",
      "next": "end",
      "x": 550, "y": 640
    },
    {
      "id": "end",
      "type": "end",
      "text": "— TEST COMPLETE —",
      "x": 400, "y": 740
    }
  ]
}
