{
  "id": "sample",
  "entryNode": "start",
  "background": null,
  "music": null,
  "nodes": [
    {
      "id": "start",
      "type": "dialogue",
      "speaker": "narrator",
      "text": "A calm evening settles over the city. The hum of neon lights fills the air.",
      "next": "intro_hero",
      "x": 400, "y": 30
    },
    {
      "id": "intro_hero",
      "type": "dialogue",
      "speaker": "hero",
      "text": "Another quiet night. I should check the rooftop.",
      "expression": "neutral",
      "next": "meet_stranger",
      "x": 400, "y": 130
    },
    {
      "id": "meet_stranger",
      "type": "dialogue",
      "speaker": "narrator",
      "text": "As you step onto the roof, a figure stands at the edge, silhouetted against the city lights.",
      "next": "stranger_speaks",
      "x": 400, "y": 230
    },
    {
      "id": "stranger_speaks",
      "type": "dialogue",
      "speaker": "mystery_man",
      "text": "You're late. I've been waiting.",
      "next": "choice_point",
      "x": 400, "y": 330
    },
    {
      "id": "choice_point",
      "type": "choice",
      "prompt": "How do you respond?",
      "next": "stay_back",
      "choices": [
        {
          "text": "\"Who are you?\"",
          "next": "who_are_you",
          "setFlag": "courage",
          "setValue": 5
        },
        {
          "text": "\"I don't have time for games.\"",
          "next": "no_time",
          "condition": "courage >= 30",
          "setFlag": "courage",
          "setValue": 10
        },
        {
          "text": "Reach for your weapon",
          "next": "reach_weapon",
          "condition": "has_weapon_permit == true"
        }
      ],
      "x": 100, "y": 430
    },
    {
      "id": "who_are_you",
      "type": "dialogue",
      "speaker": "mystery_man",
      "text": "Someone who knows what you're looking for. The question is — are you ready to find it?",
      "next": "choice_trust",
      "x": 100, "y": 530
    },
    {
      "id": "no_time",
      "type": "dialogue",
      "speaker": "mystery_man",
      "text": "Heh. That's exactly what I expected you to say.",
      "next": "choice_trust",
      "x": 300, "y": 530
    },
    {
      "id": "reach_weapon",
      "type": "event",
      "eventType": "sfx",
      "eventValue": "holster",
      "setFlag": "courage",
      "setValue": 20,
      "next": "choice_trust",
      "x": 500, "y": 530
    },
    {
      "id": "choice_trust",
      "type": "choice",
      "prompt": "What now?",
      "next": "stay_back",
      "choices": [
        {
          "text": "Trust them. Follow.",
          "next": "follow",
          "setFlag": "courage",
          "setValue": 15
        },
        {
          "text": "Stay back. This feels wrong.",
          "next": "stay_back"
        }
      ],
      "x": 250, "y": 630
    },
    {
      "id": "follow",
      "type": "dialogue",
      "speaker": "narrator",
      "text": "You step forward. The stranger nods once, then turns and disappears into the stairwell.",
      "next": "follow_2",
      "x": 400, "y": 730
    },
    {
      "id": "follow_2",
      "type": "dialogue",
      "speaker": "hero",
      "text": "Wait up! I didn't agree to anything yet!",
      "next": "scene_end",
      "x": 400, "y": 830
    },
    {
      "id": "stay_back",
      "type": "dialogue",
      "speaker": "mystery_man",
      "text": "Suit yourself. But the offer won't wait forever.",
      "next": "stay_back_2",
      "x": 400, "y": 630
    },
    {
      "id": "stay_back_2",
      "type": "dialogue",
      "speaker": "narrator",
      "text": "The figure melts into the shadows. You're alone again.",
      "next": "scene_end",
      "x": 400, "y": 730
    },
    {
      "id": "scene_end",
      "type": "end",
      "text": "To be continued...",
      "x": 400, "y": 930
    }
  ]
}
